{
	"name": "pybravia",
	"image": "mcr.microsoft.com/devcontainers/python:0-3.10-bullseye",
	"features": {},
	"customizations": {
		"vscode": {
			"settings": {
				"python.pythonPath": "/usr/local/bin/python",
				"python.languageServer": "Pylance",
				"editor.formatOnSave": true,
				"ruff.enable": true,
				"ruff.lint.run": "onSave",
				"ruff.format.run": "onSave"
			},
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"charliermarsh.ruff"
			]
		}
	},
	"postCreateCommand": "pip install uv && uv venv && . .venv/bin/activate && uv sync --all-groups"
}
